<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EduBot – AI Adaptive Learning System | SDG 4</title>
<style>
  :root {
    --blue:#1F3C88; --red:#E5243B; --green:#2E7D32;
    --gold:#F5A623; --light:#EEF2FF; --dark:#1A1A2E;
    --grey:#F5F5F7; --text:#1c1c1e; --border:#D1D5DB;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    background:#F0F4FF;color:var(--text);min-height:100vh}

  /* ── Header ── */
  header{background:linear-gradient(135deg,var(--dark) 0%,var(--blue) 100%);
    color:#fff;padding:16px 24px;display:flex;align-items:center;gap:16px;
    box-shadow:0 2px 12px rgba(0,0,0,.3)}
  .logo{background:var(--red);border-radius:10px;padding:8px 14px;
    font-weight:800;font-size:20px;letter-spacing:1px}
  .header-text h1{font-size:20px;font-weight:700}
  .header-text p{font-size:12px;opacity:.75;margin-top:2px}
  .sdg-badge{margin-left:auto;background:rgba(255,255,255,.15);
    border:1px solid rgba(255,255,255,.3);border-radius:20px;
    padding:6px 16px;font-size:12px;font-weight:600;white-space:nowrap}

  /* ── Layout ── */
  main{max-width:960px;margin:0 auto;padding:24px 16px}
  .card{background:#fff;border-radius:16px;padding:28px;
    box-shadow:0 2px 16px rgba(0,0,0,.08);margin-bottom:20px}

  /* ── Stats bar ── */
  .stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
  .stat{background:#fff;border-radius:12px;padding:14px;text-align:center;
    box-shadow:0 2px 8px rgba(0,0,0,.07)}
  .stat-val{font-size:24px;font-weight:800;color:var(--blue)}
  .stat-lbl{font-size:11px;color:#666;margin-top:2px;font-weight:500;text-transform:uppercase}

  /* ── Difficulty badge ── */
  .diff-badge{display:inline-block;padding:4px 14px;border-radius:20px;
    font-size:12px;font-weight:700;letter-spacing:.5px}
  .d1{background:#E8F5E9;color:#2E7D32} .d2{background:#E3F2FD;color:#1565C0}
  .d3{background:#FFF8E1;color:#F57F17} .d4{background:#FBE9E7;color:#BF360C}
  .d5{background:#FCE4EC;color:#880E4F}

  /* ── Subject selector ── */
  .subj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .subj-card{border:2px solid var(--border);border-radius:14px;padding:20px;
    text-align:center;cursor:pointer;transition:all .2s;background:#fff}
  .subj-card:hover{border-color:var(--blue);background:var(--light);transform:translateY(-2px)}
  .subj-card.selected{border-color:var(--blue);background:var(--light)}
  .subj-icon{font-size:36px;margin-bottom:10px}
  .subj-name{font-weight:700;font-size:15px;color:var(--blue)}
  .subj-desc{font-size:12px;color:#666;margin-top:4px}

  /* ── Question card ── */
  .q-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
  .q-num{font-size:13px;color:#888;font-weight:600}
  .q-topic{background:var(--light);color:var(--blue);border-radius:8px;
    padding:4px 12px;font-size:12px;font-weight:600}
  .q-text{font-size:18px;font-weight:600;line-height:1.5;margin-bottom:22px;
    color:var(--dark)}
  .options{display:grid;gap:12px}
  .opt{border:2px solid var(--border);border-radius:12px;padding:14px 18px;
    cursor:pointer;font-size:15px;font-weight:500;transition:all .18s;
    display:flex;align-items:center;gap:12px;background:#fff}
  .opt:hover:not(.disabled){border-color:var(--blue);background:var(--light)}
  .opt .opt-key{width:28px;height:28px;border-radius:50%;background:var(--grey);
    display:flex;align-items:center;justify-content:center;font-weight:700;
    font-size:13px;flex-shrink:0;color:var(--blue)}
  .opt.correct{border-color:var(--green);background:#E8F5E9}
  .opt.correct .opt-key{background:var(--green);color:#fff}
  .opt.wrong{border-color:var(--red);background:#FFEBEE}
  .opt.wrong .opt-key{background:var(--red);color:#fff}
  .opt.disabled{cursor:default}

  /* ── Feedback ── */
  .feedback{border-radius:12px;padding:16px 18px;margin-top:18px;
    display:none;animation:fadeIn .3s ease}
  .feedback.correct-fb{background:#E8F5E9;border-left:4px solid var(--green)}
  .feedback.wrong-fb{background:#FFEBEE;border-left:4px solid var(--red)}
  .fb-title{font-weight:700;font-size:14px;margin-bottom:8px}
  .fb-text{font-size:13.5px;line-height:1.6;color:#333}
  .fb-ai{margin-top:10px;padding-top:10px;border-top:1px solid rgba(0,0,0,.1);
    font-size:13px;color:#555;line-height:1.6}
  .ai-tag{background:var(--blue);color:#fff;font-size:10px;font-weight:700;
    padding:2px 8px;border-radius:10px;margin-right:8px}
  .thinking{font-style:italic;color:#888;font-size:13px}

  /* ── Progress bar ── */
  .progress-wrap{background:var(--grey);border-radius:10px;height:8px;overflow:hidden}
  .progress-bar{height:100%;border-radius:10px;background:linear-gradient(90deg,var(--blue),var(--green));
    transition:width .5s ease}

  /* ── Buttons ── */
  .btn{border:none;border-radius:10px;padding:13px 28px;font-size:15px;
    font-weight:700;cursor:pointer;transition:all .2s}
  .btn-primary{background:var(--blue);color:#fff}
  .btn-primary:hover{background:#162d6a;transform:translateY(-1px)}
  .btn-success{background:var(--green);color:#fff}
  .btn-success:hover{background:#1b5e20}
  .btn-danger{background:var(--red);color:#fff}
  .btn-danger:hover{background:#b71c1c}

  /* ── Results ── */
  .score-circle{width:160px;height:160px;border-radius:50%;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    margin:0 auto 24px;font-weight:800;box-shadow:0 4px 20px rgba(0,0,0,.15)}
  .score-pct{font-size:42px}
  .score-lbl{font-size:13px;opacity:.85}
  .result-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:20px 0}
  .result-item{background:var(--grey);border-radius:10px;padding:14px;text-align:center}
  .result-item strong{display:block;font-size:22px;color:var(--blue);font-weight:800}
  .result-item span{font-size:12px;color:#666;font-weight:500}
  .perf-row{display:flex;justify-content:space-between;align-items:center;
    padding:10px 0;border-bottom:1px solid var(--grey)}
  .perf-topic{font-weight:600;font-size:14px}
  .perf-bar-wrap{width:180px;background:var(--grey);border-radius:6px;height:8px}
  .perf-bar{height:8px;border-radius:6px;background:var(--blue)}
  .perf-score{font-size:13px;font-weight:700;color:var(--blue);min-width:40px;text-align:right}

  /* ── Start screen ── */
  .hero{text-align:center;padding:10px 0 20px}
  .hero h2{font-size:28px;font-weight:800;color:var(--dark);margin-bottom:8px}
  .hero p{font-size:15px;color:#555;max-width:520px;margin:0 auto 24px}
  .how-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:24px 0}
  .step{background:var(--grey);border-radius:12px;padding:18px;text-align:center}
  .step-num{width:36px;height:36px;border-radius:50%;background:var(--blue);color:#fff;
    display:flex;align-items:center;justify-content:center;font-weight:800;
    font-size:16px;margin:0 auto 10px}
  .step-title{font-weight:700;font-size:14px;color:var(--dark);margin-bottom:4px}
  .step p{font-size:12px;color:#666}

  /* ── Misc ── */
  @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
  .hidden{display:none!important}
  .flex{display:flex} .gap-3{gap:12px} .mt-4{margin-top:16px} .mt-2{margin-top:8px}
  .text-center{text-align:center} .w-full{width:100%}
  .streak{display:inline-flex;align-items:center;gap:6px;background:#FFF8E1;
    border-radius:20px;padding:4px 12px;font-size:13px;font-weight:700;color:#E65100}
</style>
</head>
<body>

<header>
  <div class="logo">SDG 4</div>
  <div class="header-text">
    <h1>🤖 EduBot – AI Adaptive Learning System</h1>
    <p>Personalised Education · Quality for All · Powered by AI</p>
  </div>
  <div class="sdg-badge">🎯 UN SDG 4: Quality Education</div>
</header>

<main>
  <!-- Stats bar -->
  <div class="stats-bar" id="statsBar">
    <div class="stat"><div class="stat-val" id="sQ">0</div><div class="stat-lbl">Questions</div></div>
    <div class="stat"><div class="stat-val" id="sC" style="color:var(--green)">0</div><div class="stat-lbl">Correct</div></div>
    <div class="stat"><div class="stat-val" id="sAcc">—</div><div class="stat-lbl">Accuracy</div></div>
    <div class="stat"><div class="stat-val" id="sDiff">—</div><div class="stat-lbl">Difficulty</div></div>
  </div>

  <!-- ── SCREEN: Start ── -->
  <div id="screenStart" class="card">
    <div class="hero">
      <div style="font-size:56px;margin-bottom:12px">📚</div>
      <h2>Welcome to EduBot</h2>
      <p>An AI-powered adaptive quiz that adjusts to your level in real time — giving you personalised questions and intelligent feedback.</p>
    </div>
    <div class="how-steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-title">Choose Subject</div>
        <p>Pick from Math, Science, or Computer Science</p>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-title">Adaptive Quiz</div>
        <p>Questions auto-adjust based on your answers</p>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-title">AI Feedback</div>
        <p>Get instant AI explanations for every question</p>
      </div>
    </div>
    <div class="subj-grid" id="subjGrid">
      <div class="subj-card" onclick="selectSubject('math')">
        <div class="subj-icon">🔢</div>
        <div class="subj-name">Mathematics</div>
        <div class="subj-desc">Algebra, Geometry & Arithmetic</div>
      </div>
      <div class="subj-card" onclick="selectSubject('science')">
        <div class="subj-icon">🔬</div>
        <div class="subj-name">Science</div>
        <div class="subj-desc">Physics, Chemistry & Biology</div>
      </div>
      <div class="subj-card" onclick="selectSubject('cs')">
        <div class="subj-icon">💻</div>
        <div class="subj-name">Computer Science</div>
        <div class="subj-desc">Programming, AI & Data Structures</div>
      </div>
    </div>
    <div class="text-center mt-4">
      <button class="btn btn-primary" id="startBtn" onclick="startQuiz()" style="display:none;margin-top:20px">
        🚀 Start Adaptive Quiz
      </button>
    </div>
  </div>

  <!-- ── SCREEN: Quiz ── -->
  <div id="screenQuiz" class="hidden">
    <div class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
        <div>
          <span class="q-num" id="qNum">Question 1 of 10</span>
          <span id="streakBadge" class="streak hidden" style="margin-left:10px">🔥 <span id="streakNum">0</span> streak</span>
        </div>
        <span id="diffBadge" class="diff-badge d3">Level 3</span>
      </div>
      <div class="progress-wrap" style="margin-bottom:18px">
        <div class="progress-bar" id="progressBar" style="width:0%"></div>
      </div>
      <div class="q-header">
        <span class="q-topic" id="qTopic">Topic</span>
      </div>
      <div class="q-text" id="qText">Loading question...</div>
      <div class="options" id="optionsContainer"></div>
      <div class="feedback" id="feedbackBox">
        <div class="fb-title" id="fbTitle"></div>
        <div class="fb-text" id="fbText"></div>
        <div class="fb-ai" id="fbAI"></div>
      </div>
      <div class="flex gap-3 mt-4" style="justify-content:flex-end">
        <button class="btn btn-primary hidden" id="nextBtn" onclick="nextQuestion()">
          Next Question →
        </button>
      </div>
    </div>
  </div>

  <!-- ── SCREEN: Results ── -->
  <div id="screenResults" class="hidden">
    <div class="card text-center">
      <h2 style="font-size:22px;font-weight:800;margin-bottom:20px;color:var(--dark)">
        📊 Your Session Report
      </h2>
      <div class="score-circle" id="scoreCircle">
        <div class="score-pct" id="scorePct">0%</div>
        <div class="score-lbl">Final Score</div>
      </div>
      <div class="result-grid">
        <div class="result-item"><strong id="rCorrect">0</strong><span>Correct</span></div>
        <div class="result-item"><strong id="rTotal">0</strong><span>Questions</span></div>
        <div class="result-item"><strong id="rMax">0</strong><span>Max Streak</span></div>
        <div class="result-item"><strong id="rDiff">—</strong><span>Final Level</span></div>
      </div>
      <div id="aiSummary" style="background:var(--light);border-radius:12px;padding:16px;margin:16px 0;text-align:left">
        <div style="font-weight:700;margin-bottom:8px;color:var(--blue)">🤖 AI Performance Summary</div>
        <div id="aiSummaryText" class="thinking">Generating personalised summary...</div>
      </div>
      <div id="topicBreakdown" style="text-align:left;margin-bottom:20px"></div>
      <div class="flex gap-3" style="justify-content:center">
        <button class="btn btn-primary" onclick="restartQuiz()">🔄 Try Again</button>
        <button class="btn btn-success" onclick="changeSubject()">📚 Change Subject</button>
      </div>
    </div>
  </div>
</main>

<script>
// ── Question Bank ─────────────────────────────────────────────────────────────
const QB = {
  math: [
    // Level 1
    {d:1,topic:"Arithmetic",q:"What is 15 + 28?",opts:["41","43","45","42"],ans:1,exp:"15 + 28 = 43. Add ones: 5+8=13, carry 1. Tens: 1+2+1=4. Answer: 43."},
    {d:1,topic:"Arithmetic",q:"What is 9 × 7?",opts:["56","54","63","72"],ans:2,exp:"9 × 7 = 63. You can remember: 9 × 7, think 9 groups of 7 = 63."},
    {d:1,topic:"Fractions",q:"What is ½ + ¼?",opts:["2/6","3/8","3/4","1/3"],ans:2,exp:"½ = 2/4. So 2/4 + 1/4 = 3/4. Always find a common denominator first."},
    // Level 2
    {d:2,topic:"Algebra",q:"Solve: 2x + 5 = 13",opts:["x = 4","x = 9","x = 3","x = 6"],ans:0,exp:"2x = 13 − 5 = 8, so x = 8/2 = 4. Isolate x by moving constants to the right."},
    {d:2,topic:"Geometry",q:"Area of a rectangle with length 8 and width 5?",opts:["26","13","40","45"],ans:2,exp:"Area = length × width = 8 × 5 = 40 square units."},
    {d:2,topic:"Percentages",q:"What is 20% of 150?",opts:["25","30","35","20"],ans:1,exp:"20% = 20/100 = 0.2. 0.2 × 150 = 30."},
    // Level 3
    {d:3,topic:"Algebra",q:"If f(x) = x² - 3x + 2, what is f(4)?",opts:["6","8","10","4"],ans:0,exp:"f(4) = 16 − 12 + 2 = 6. Substitute x=4 into the expression."},
    {d:3,topic:"Geometry",q:"A circle has radius 7. What is its area? (π ≈ 3.14)",opts:["153.86","43.96","49","21.98"],ans:0,exp:"Area = πr² = 3.14 × 7² = 3.14 × 49 = 153.86 square units."},
    {d:3,topic:"Statistics",q:"Mean of [4, 8, 6, 5, 3, 2, 8, 9, 2, 5]?",opts:["5","5.2","4.8","6"],ans:1,exp:"Sum = 52. Count = 10. Mean = 52/10 = 5.2."},
    // Level 4
    {d:4,topic:"Quadratics",q:"Roots of x² - 5x + 6 = 0?",opts:["2,3","1,6","-2,-3","3,4"],ans:0,exp:"Factor: (x-2)(x-3) = 0. Roots are x=2 and x=3."},
    {d:4,topic:"Trigonometry",q:"sin(30°) = ?",opts:["√3/2","1/2","1","√2/2"],ans:1,exp:"sin(30°) = 1/2. This is a standard value to memorise from the unit circle."},
    // Level 5
    {d:5,topic:"Calculus",q:"Derivative of f(x) = 3x³ + 2x²?",opts:["9x² + 4x","6x² + 2x","9x + 4","3x² + 2x"],ans:0,exp:"d/dx(3x³) = 9x². d/dx(2x²) = 4x. So f'(x) = 9x² + 4x."},
    {d:5,topic:"Probability",q:"P(A∪B) if P(A)=0.4, P(B)=0.3, P(A∩B)=0.1?",opts:["0.7","0.6","0.5","0.8"],ans:1,exp:"P(A∪B) = P(A)+P(B)−P(A∩B) = 0.4+0.3−0.1 = 0.6."},
  ],
  science: [
    {d:1,topic:"Physics",q:"What is the unit of force?",opts:["Joule","Newton","Watt","Pascal"],ans:1,exp:"Force is measured in Newtons (N), named after Isaac Newton. F = ma."},
    {d:1,topic:"Biology",q:"What is the powerhouse of the cell?",opts:["Nucleus","Ribosome","Mitochondria","Golgi body"],ans:2,exp:"Mitochondria produce ATP through cellular respiration — the cell's energy currency."},
    {d:1,topic:"Chemistry",q:"Chemical symbol for Gold?",opts:["Go","Gd","Au","Ag"],ans:2,exp:"Gold is 'Au' from Latin 'Aurum'. Silver is Ag, Platinum is Pt."},
    {d:2,topic:"Physics",q:"Speed of light in vacuum?",opts:["3×10⁸ m/s","3×10⁶ m/s","3×10¹⁰ m/s","3×10⁴ m/s"],ans:0,exp:"c ≈ 3×10⁸ m/s (299,792,458 m/s). This is a fundamental constant in physics."},
    {d:2,topic:"Chemistry",q:"Number of protons in Carbon (C)?",opts:["12","6","8","4"],ans:1,exp:"Carbon's atomic number is 6, meaning it has 6 protons. Atomic mass is 12 (6p + 6n)."},
    {d:2,topic:"Biology",q:"Which blood type is universal donor?",opts:["A","AB","B","O−"],ans:3,exp:"O− has no A, B, or Rh antigens, so it can be given to anyone in emergency."},
    {d:3,topic:"Physics",q:"KE of object with m=5kg, v=10m/s?",opts:["50J","250J","100J","500J"],ans:1,exp:"KE = ½mv² = ½ × 5 × 100 = 250 Joules."},
    {d:3,topic:"Chemistry",q:"pH of a neutral solution at 25°C?",opts:["0","14","7","1"],ans:2,exp:"pH 7 is neutral. < 7 is acidic, > 7 is basic/alkaline."},
    {d:4,topic:"Physics",q:"Einstein's mass-energy equivalence?",opts:["E=mc","E=mc²","E=m²c","E=mc³"],ans:1,exp:"E=mc² shows that mass and energy are interconvertible. c is speed of light."},
    {d:4,topic:"Biology",q:"Which enzyme unwinds DNA during replication?",opts:["Ligase","Polymerase","Helicase","Topoisomerase"],ans:2,exp:"Helicase breaks hydrogen bonds between base pairs to unwind the double helix."},
    {d:5,topic:"Quantum Physics",q:"Heisenberg's uncertainty principle relates?",opts:["Mass & velocity","Position & momentum","Energy & charge","Temperature & entropy"],ans:1,exp:"Δx·Δp ≥ ℏ/2. You cannot simultaneously know exact position and momentum."},
    {d:5,topic:"Chemistry",q:"Hybridisation of carbon in methane (CH₄)?",opts:["sp","sp²","sp³","sp³d"],ans:2,exp:"Methane has 4 sigma bonds, requiring sp³ hybridisation (tetrahedral geometry, 109.5°)."},
  ],
  cs: [
    {d:1,topic:"Basics",q:"What does CPU stand for?",opts:["Central Processing Unit","Computer Personal Unit","Core Processing Unit","Central Program Unit"],ans:0,exp:"CPU = Central Processing Unit. It performs arithmetic, logic, control, and I/O operations."},
    {d:1,topic:"Programming",q:"Which symbol starts a single-line comment in Python?",opts:["//","/*","#","--"],ans:2,exp:"Python uses # for comments. C/C++/Java use // for single-line comments."},
    {d:1,topic:"Data",q:"How many bits in a byte?",opts:["4","16","8","32"],ans:2,exp:"1 byte = 8 bits. 1 KB = 1024 bytes. 1 MB = 1024 KB."},
    {d:2,topic:"Data Structures",q:"Time complexity of binary search?",opts:["O(n)","O(n²)","O(log n)","O(1)"],ans:2,exp:"Binary search halves the search space each step → O(log n). Requires sorted array."},
    {d:2,topic:"Programming",q:"Output of: print(type(3/2)) in Python 3?",opts:["int","float","double","number"],ans:1,exp:"In Python 3, / always returns float. 3/2 = 1.5. Use // for integer division."},
    {d:2,topic:"Networking",q:"What does HTTP stand for?",opts:["HyperText Transfer Protocol","High Transfer Text Protocol","Home Tool Transfer Process","HyperText Transmission Path"],ans:0,exp:"HTTP = HyperText Transfer Protocol. HTTPS adds SSL/TLS encryption for security."},
    {d:3,topic:"Algorithms",q:"Which sorting algorithm has worst-case O(n log n)?",opts:["Bubble Sort","Quick Sort","Merge Sort","Insertion Sort"],ans:2,exp:"Merge Sort guarantees O(n log n) in all cases. Quick Sort is O(n²) worst case."},
    {d:3,topic:"AI/ML",q:"In supervised learning, training data must have?",opts:["Only features","Only labels","Both features and labels","Neither"],ans:2,exp:"Supervised learning needs labelled data — input features paired with correct output labels."},
    {d:3,topic:"OS",q:"What prevents deadlock using resource ordering?",opts:["Semaphore","Banker's algorithm","Mutex","Monitor"],ans:1,exp:"Banker's Algorithm checks safe state before allocating resources, preventing deadlock."},
    {d:4,topic:"AI/ML",q:"Activation function that solves vanishing gradient?",opts:["Sigmoid","Tanh","ReLU","Softmax"],ans:2,exp:"ReLU (max(0,x)) doesn't saturate for positive values, mitigating the vanishing gradient problem."},
    {